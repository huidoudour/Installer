<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true"
    tools:context=".ui.ShellFragment">

    <!-- 命令输入区域 - Material You 风格 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/inputCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHighest"
        app:strokeWidth="2dp"
        app:strokeColor="?attr/colorPrimary">

        <LinearLayout
            android:id="@+id/inputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/colorSurfaceContainerHighest"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- 命令输入框 -->
            <EditText
                android:id="@+id/etCommandInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textNoSuggestions"
                android:maxLines="1"
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="monospace"
                android:background="@android:color/transparent"
                android:textCursorDrawable="@null"
                android:hint="Enter command..."
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:imeOptions="actionSend|flagNoExtractUi" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 功能键容器 (包含8个按钮) - Material You 风格 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/functionKeysCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/inputCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainer"
        app:strokeWidth="1dp"
        app:strokeColor="?attr/colorOutlineVariant">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="false">

            <LinearLayout
                android:id="@+id/functionKeysContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="?attr/colorSurfaceContainer"
                android:padding="8dp"
                android:gravity="center_vertical">

            <!-- 上箭头 (历史上一条) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistoryUp"
                android:layout_width="44dp"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:padding="0dp"
                android:text="↑"
                android:textSize="16sp"
                android:textColor="?attr/colorOnTertiaryContainer"
                android:layout_marginEnd="4dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- 下箭头 (历史下一条) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistoryDown"
                android:layout_width="44dp"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:padding="0dp"
                android:text="↓"
                android:textSize="16sp"
                android:textColor="?attr/colorOnTertiaryContainer"
                android:layout_marginEnd="4dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- Tab键 (自动补全) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTab"
                android:layout_width="54dp"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:padding="0dp"
                android:text="TAB"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:layout_marginEnd="4dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- Ctrl+C (终止命令) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCtrlC"
                android:layout_width="54dp"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:padding="0dp"
                android:text="^C"
                android:textSize="12sp"
                android:textColor="?attr/colorError"
                android:layout_marginEnd="4dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- ESC键 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEsc"
                android:layout_width="54dp"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:padding="0dp"
                android:text="ESC"
                android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginEnd="8dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- 清屏按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearScreen"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:padding="0dp"
                android:text="C"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:layout_marginEnd="4dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- 复制按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopyOutput"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:padding="0dp"
                android:text="@string/clipboard"
                android:textSize="12sp"
                android:layout_marginEnd="4dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- 快捷命令按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnQuickCommands"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:padding="0dp"
                android:text="@string/lightning"
                android:textSize="12sp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />
            </LinearLayout>
        </HorizontalScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- 顶部工具栏 - Material You 风格 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/toolbarCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainer"
        app:strokeWidth="1dp"
        app:strokeColor="?attr/colorOutlineVariant">

        <LinearLayout
            android:id="@+id/toolbarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="?attr/colorSurfaceContainer"
            android:padding="4dp"
            android:gravity="center">

            <!-- 历史命令按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistory"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="2dp"
                android:contentDescription="@string/content_description_history"
                app:icon="@drawable/ic_shell_history"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- 书签按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBookmarks"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:contentDescription="@string/content_description_bookmarks"
                app:icon="@drawable/ic_shell_bookmark"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- 搜索输出按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSearchOutput"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:contentDescription="@string/content_description_search"
                app:icon="@drawable/ic_shell_search"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <!-- 保存输出按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveOutput"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginStart="2dp"
                android:contentDescription="@string/content_description_save"
                app:icon="@drawable/ic_shell_save"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:cornerRadius="8dp"
                style="@style/Widget.Material3.Button.TonalButton" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 搜索框（默认隐藏） -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/toolbarCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHighest"
        app:strokeWidth="2dp"
        app:strokeColor="?attr/colorPrimary">

        <EditText
            android:id="@+id/etSearchInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"
            android:fontFamily="monospace"
            android:background="@android:color/transparent"
            android:hint="Search in output..."
            android:textColorHint="?attr/colorOnSurfaceVariant"
            android:padding="12dp"
            android:imeOptions="actionSearch" />
    </com.google.android.material.card.MaterialCardView>

    <!-- 终端输出区域 - Material You 风格 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewOutput"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/searchCard"
        app:layout_constraintBottom_toTopOf="@+id/functionKeysCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="8dp"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:fillViewport="true">

        <androidx.cardview.widget.CardView
            android:id="@+id/outputCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant">

            <TextView
                android:id="@+id/tvTerminalOutput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4dp"
                android:textIsSelectable="true"
                android:background="?attr/colorSurfaceVariant" />
        </androidx.cardview.widget.CardView>
    </androidx.core.widget.NestedScrollView>

    <!-- 快速滚动按钮 -->
    <LinearLayout
        android:id="@+id/scrollButtonsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/functionKeysCard"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <!-- 滚动到顶部 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScrollTop"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:text="↑"
            android:textSize="18sp"
            android:layout_marginBottom="4dp"
            app:cornerRadius="20dp"
            style="@style/Widget.Material3.Button.TonalButton" />

        <!-- 滚动到底部 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScrollBottom"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:text="↓"
            android:textSize="18sp"
            app:cornerRadius="20dp"
            style="@style/Widget.Material3.Button.TonalButton" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
