<?xml version="1.0" encoding="utf-8"?>
<!-- 安装对话框 - 纯安装UI -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- 圆角对话框容器 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== STEP 1: 安装确认界面 ===== -->
            <LinearLayout
                android:id="@+id/layout_install_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 应用图标和名称区域 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:id="@+id/iv_app_icon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/sym_def_app_icon"
                        android:scaleType="centerInside"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@string/app_icon_description" />

                    <TextView
                        android:id="@+id/tv_app_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/app_name_label"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:maxLines="2"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- 应用信息区域 - 居中显示 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <!-- 包名 -->
                    <TextView
                        android:id="@+id/tv_package_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="包名：com.example.app"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <!-- 当前版本 -->
                    <TextView
                        android:id="@+id/tv_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="当前版本：1.0.0"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="center" />

                    <!-- 下箭头 -->
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_down"
                        android:contentDescription="@string/arrow_down"
                        android:layout_marginVertical="4dp" />

                    <!-- 升级版本 -->
                    <TextView
                        android:id="@+id/tv_upgrade_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="升级版本：1.1.0"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <!-- 最低SDK -->
                    <TextView
                        android:id="@+id/tv_min_sdk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="最低SDK：21"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="center"
                        android:layout_marginBottom="4dp" />

                    <!-- 目标SDK -->
                    <TextView
                        android:id="@+id/tv_target_sdk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="目标SDK：34"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="center" />

                </LinearLayout>

                <!-- 按钮区域：安装时切换为进度显示 -->
                <LinearLayout
                    android:id="@+id/layout_buttons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 安装按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_install"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/install"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:cornerRadius="16dp"
                        app:elevation="4dp"
                        app:backgroundTint="@color/button_secondary"
                        android:layout_marginBottom="8dp" />

                    <!-- 按钮行：权限和取消 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_privilege"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="@string/privilege"
                            android:textSize="14sp"
                            app:cornerRadius="12dp"
                            app:backgroundTint="@color/button_primary"
                            android:layout_marginEnd="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_cancel"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="@string/cancel"
                            android:textSize="14sp"
                            app:cornerRadius="12dp"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            app:strokeColor="?attr/colorOutline"
                            app:strokeWidth="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 进度区域：安装时显示 -->
                <LinearLayout
                    android:id="@+id/layout_installing_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- 线性进度条 -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progress_install"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:trackThickness="8dp"
                        app:trackCornerRadius="4dp"
                        app:indicatorColor="@color/button_primary"
                        app:trackColor="?attr/colorSurfaceContainerHighest"
                        android:indeterminate="true" />

                    <!-- 取消按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_cancel_progress"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="@string/cancel"
                        android:textSize="14sp"
                        app:cornerRadius="16dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:strokeColor="?attr/colorOutline"
                        app:strokeWidth="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== STEP 2: 安装完成界面 ===== -->
            <LinearLayout
                android:id="@+id/layout_completion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <!-- 打开应用按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_app"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/open_app"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:elevation="4dp"
                    app:backgroundTint="@color/button_primary"
                    android:layout_marginBottom="8dp" />

                <!-- 按钮行：返回和完成 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_completion_back"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/back"
                        android:textSize="14sp"
                        app:cornerRadius="12dp"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        app:strokeColor="?attr/colorOutline"
                        app:strokeWidth="2dp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_finish"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/finish"
                        android:textSize="14sp"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </LinearLayout>


        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
