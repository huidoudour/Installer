<?xml version="1.0" encoding="utf-8"?>
<!-- 安装对话布局 - Material Design 3 精美风格 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- 圆角对话框容器 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- 应用图标和名称区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">
                
                <!-- 应用图标（直接展示） -->
                <ImageView
                    android:id="@+id/iv_app_icon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/sym_def_app_icon"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="16dp"
                    android:contentDescription="@string/app_icon_description" />
                    
                <!-- 应用名称 -->
                <TextView
                    android:id="@+id/tv_app_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/app_name_label"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- 应用信息卡片（美化版） -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                android:layout_marginBottom="24dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    
                    <!-- 包名信息 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/package_name"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginEnd="16dp" />
                            
                        <TextView
                            android:id="@+id/tv_package_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="com.example.app"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurface"
                            android:textAlignment="textEnd"
                            android:maxLines="2"
                            android:ellipsize="end" />
                    </LinearLayout>
                    
                    <!-- 版本信息 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/version"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginEnd="16dp" />
                            
                        <TextView
                            android:id="@+id/tv_version"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1.0.0"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurface"
                            android:textAlignment="textEnd" />
                    </LinearLayout>
                    
                    <!-- 文件大小 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/file_size"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginEnd="16dp" />
                            
                        <TextView
                            android:id="@+id/tv_file_size"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="10.5 MB"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurface"
                            android:textAlignment="textEnd" />
                    </LinearLayout>
                    
                    <!-- 最小SDK版本 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/min_sdk"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginEnd="16dp" />
                            
                        <TextView
                            android:id="@+id/tv_min_sdk"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/unknown"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurface"
                            android:textAlignment="textEnd" />
                    </LinearLayout>
                    
                    <!-- 目标SDK版本 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/target_sdk"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginEnd="16dp" />
                            
                        <TextView
                            android:id="@+id/tv_target_sdk"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/unknown"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurface"
                            android:textAlignment="textEnd" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 按钮区域 -->
            <LinearLayout
                android:id="@+id/layout_install_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                
                <!-- 安装按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_install"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/install"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:elevation="4dp"
                    app:backgroundTint="@color/button_primary"
                    android:layout_marginBottom="12dp" />
                    
                <!-- 取消按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/cancel"
                    android:textSize="16sp"
                    app:cornerRadius="16dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="2dp" />
            </LinearLayout>

            <!-- 安装完成布局 -->
            <LinearLayout
                android:id="@+id/layout_completion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">
                
                <!-- 打开应用按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_app"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/open_app"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:elevation="4dp"
                    app:backgroundTint="@color/button_primary"
                    android:layout_marginBottom="12dp" />
                    
                <!-- 完成按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_finish"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/finish"
                    android:textSize="16sp"
                    app:cornerRadius="16dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="2dp" />
            </LinearLayout>

            <!-- 安装中状态布局 -->
            <LinearLayout
                android:id="@+id/layout_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                
                <!-- 线性进度条 -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_install"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:trackThickness="8dp"
                    app:trackCornerRadius="4dp"
                    app:indicatorColor="@color/button_primary"
                    app:trackColor="?attr/colorSurfaceContainerHighest"
                    android:indeterminate="false"
                    android:progress="0" />
                
                <!-- 进度详情文本 -->
                <TextView
                    android:id="@+id/tv_progress_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/preparing"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginBottom="20dp" />
                
                <!-- 取消按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel_progress"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/cancel"
                    android:textSize="16sp"
                    app:cornerRadius="16dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="2dp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
