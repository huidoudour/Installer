<?xml version="1.0" encoding="utf-8"?>
<!-- 权限选择对话框 - 独立对话框 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/select_privilege_mode"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="16dp" />

    <!-- Shizuku 选项 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_shizuku"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Shizuku 图标 -->
            <ImageView
                android:id="@+id/iv_shizuku_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_warning"
                android:contentDescription="@string/shizuku" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/shizuku"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_shizuku_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/checking"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- 选择指示器 -->
            <RadioButton
                android:id="@+id/rb_shizuku"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Dhizuku 选项 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_dhizuku"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
        android:layout_marginBottom="16dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Dhizuku 图标 -->
            <ImageView
                android:id="@+id/iv_dhizuku_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_warning"
                android:contentDescription="@string/dhizuku" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dhizuku"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_dhizuku_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/checking"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- 选择指示器 -->
            <RadioButton
                android:id="@+id/rb_dhizuku"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="false" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 授权按钮区域 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_shizuku_grant"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/request_authorization"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cornerRadius="12dp"
        style="@style/Widget.Material3.Button.TonalButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_dhizuku_grant"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/request_authorization"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:cornerRadius="12dp"
        style="@style/Widget.Material3.Button.TonalButton" />

    <!-- 按钮行：取消和下一步 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_privilege_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/cancel"
            android:textSize="14sp"
            app:cornerRadius="12dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="?attr/colorOutline"
            app:strokeWidth="2dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_privilege_next"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/next_step"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/button_secondary_tint" />
    </LinearLayout>

</LinearLayout>
